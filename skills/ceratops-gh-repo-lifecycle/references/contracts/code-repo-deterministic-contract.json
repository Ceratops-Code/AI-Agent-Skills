{
  "contract_format_version": 2,
  "kind": "repo_code_contract",
  "name": "ceratops_code_repo_deterministic_contract",
  "captured_on": "2026-05-02",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-gh-repo-lifecycle/references/contract-source-docs.json",
      "lines": "source-doc registry"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-gh-repo-lifecycle/references/health-audit.md",
      "lines": "contract owner"
    }
  ],
  "parameters": {
    "owner": {
      "type": "string",
      "required": true
    },
    "repo": {
      "type": "string",
      "required": true
    },
    "default_branch": {
      "type": "string",
      "required": false,
      "default_from": "repo.default_branch"
    },
    "expected_codeowners_owners": {
      "type": "array",
      "required": false,
      "default": []
    },
    "expected_required_checks": {
      "type": "array",
      "required": false,
      "default": []
    },
    "artifact_publishers": {
      "type": "array",
      "required": false,
      "default": []
    },
    "local_repo_path": {
      "type": "string",
      "required": false
    },
    "expected_maintainer_bypass_actors": {
      "type": "array",
      "required": false,
      "default": []
    },
    "approved_drift_profile": {
      "type": "string",
      "required": false,
      "default": "default"
    }
  },
  "required_scopes": [
    "repo"
  ],
  "optional_scopes_for_full_screen_parity": [],
  "source_docs_ref": "contract-source-docs.json",
  "source_doc_scopes": [
    "repo"
  ],
  "approved_drift": {
    "exclusions": [],
    "allowances": [
      {
        "id": "archived_repos_report_only",
        "when": "repo.archived == true",
        "check_ids": [
          "*"
        ],
        "reason": "Archived repositories are immutable health inventory, not repair targets."
      }
    ]
  },
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": null,
    "destructive_or_irreversible": "always_report_only"
  },
  "fetch_bundles": [
    {
      "id": "repo_content_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/git/trees/${default_branch}?recursive=1",
          "covers_checks": [
            "type.path_signals",
            "content.required_files_presence",
            "security.dependabot_config_file",
            "stale_state.local_path_references"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/languages",
          "covers_checks": [
            "type.language_signals"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/codeowners/errors",
          "covers_checks": [
            "content.codeowners_valid"
          ]
        }
      ]
    },
    {
      "id": "local_repo_scan_bundle",
      "sources": [
        "${local_repo_path}"
      ],
      "covers_checks": [
        "type.path_signals",
        "actions.workflow_sha_pinning",
        "security.dependabot_config_file",
        "content.required_files_presence",
        "local.git_state",
        "content.local_secret_pattern_scan",
        "stale_state.local_path_references"
      ],
      "applies_when": "local_repo_path is provided"
    }
  ],
  "checks": [
    {
      "id": "type.path_signals",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "classification",
      "applies_when": "always",
      "assertions": [
        {
          "path": "/repository/types",
          "operator": "truthy"
        }
      ]
    },
    {
      "id": "type.language_signals",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "classification",
      "applies_when": "always",
      "assertions": [
        {
          "path": "/repository/types/language_or_iac",
          "operator": "not_empty"
        }
      ]
    },
    {
      "id": "actions.workflow_sha_pinning",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "tree_scan",
      "applies_when": "type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/local/available",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/local/workflows/unpinned_external_refs",
          "operator": "empty"
        }
      ]
    },
    {
      "id": "security.dependabot_config_file",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "tree_scan",
      "applies_when": "repo.archived == false && repo.fork == false && package_manifests_present == true",
      "assertions": [
        {
          "path": "/repository/content/dependabot/config_present",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/content/dependabot/text_available",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/content/dependabot/missing_ecosystems",
          "operator": "empty",
          "level": "WARN"
        },
        {
          "path": "/repository/content/dependabot/updates_present",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/content/dependabot/schedule_present",
          "operator": "equal",
          "expected": true
        }
      ]
    },
    {
      "id": "content.required_files_presence",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api_and_tree",
      "applies_when": "repo.archived == false",
      "assertions": [
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": "README.md"
        },
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": "LICENSE",
          "when": "repo.visibility == public && repo.fork == false"
        },
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": "SECURITY.md",
          "when": "repo.visibility == public && repo.fork == false"
        },
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": "CONTRIBUTING.md",
          "when": "repo.visibility == public && repo.fork == false"
        },
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": "CODE_OF_CONDUCT.md",
          "when": "repo.visibility == public && repo.fork == false"
        },
        {
          "path": "/repository/paths",
          "operator": "glob_present",
          "expected": ".github/CODEOWNERS",
          "when": "repo.visibility == public && repo.fork == false"
        }
      ]
    },
    {
      "id": "content.codeowners_valid",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/codeowners/errors",
      "applies_when": "repository.codeowners_present",
      "assertions": [
        {
          "path": "/repository/content/codeowners_errors_available",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/repository/content/codeowners_errors",
          "operator": "empty"
        }
      ]
    },
    {
      "id": "local.git_state",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md",
        "skills/ceratops-gh-repo-lifecycle/references/create-or-publish.md"
      ],
      "kind": "local_git",
      "applies_when": "local_repo_path is provided",
      "assertions": [
        {
          "path": "/local/git/available",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/local/git/worktree_clean",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/local/git/current_branch",
          "operator": "equal",
          "expected": "${default_branch}",
          "level": "WARN"
        },
        {
          "path": "/local/git/tracks_remote_default_branch",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        }
      ]
    },
    {
      "id": "stale_state.local_path_references",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "tree_scan",
      "applies_when": "local_repo_path is provided && repo.archived == false",
      "assertions": [
        {
          "path": "/local/scans/stale_state.local_path_references/matches",
          "operator": "empty",
          "level": "NEEDS_AI_AGENT_REVIEW"
        }
      ],
      "collection": {
        "regex_patterns": [
          "(?<![A-Za-z0-9_])[A-Za-z]:\\\\",
          "/Users/",
          "/home/[^/]+/"
        ],
        "ignore_paths": [
          "skills/ceratops-gh-repo-lifecycle/references/contracts/code-repo-deterministic-contract.json"
        ]
      }
    },
    {
      "id": "content.local_secret_pattern_scan",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/scripts/github_contract_engine/collectors/local_repository.py:collect_local_repository",
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "tree_scan",
      "applies_when": "local_repo_path is provided && repo.archived == false",
      "assertions": [
        {
          "path": "/local/scans/content.local_secret_pattern_scan/matches",
          "operator": "empty"
        }
      ],
      "collection": {
        "regex_patterns": [
          "AKIA[0-9A-Z]{16}",
          "gh[pousr]_[A-Za-z0-9_]{20,}",
          "github_pat_[A-Za-z0-9_]{20,}",
          "sk-[A-Za-z0-9_-]{20,}",
          "xox[baprs]-[A-Za-z0-9-]{10,}",
          "BEGIN (?:RSA |OPENSSH |EC |DSA )?PRIVATE KEY"
        ],
        "ignore_paths": []
      }
    }
  ],
  "non_deterministic_review_file": "code-repo-nondeterministic-contract.json"
}
