{
  "contract_format_version": 2,
  "kind": "github_organization_contract",
  "name": "ceratops_github_org_deterministic_contract",
  "captured_from": "Ceratops-Code",
  "captured_on": "2026-05-01",
  "parameters": {
    "org_login": {
      "type": "string",
      "required": true
    },
    "billing_email": {
      "type": "string",
      "required": true
    },
    "owner_login": {
      "type": "string",
      "required": true
    }
  },
  "required_scopes": [
    "admin:org",
    "admin:org_hook",
    "repo",
    "workflow"
  ],
  "source_docs_ref": "contract-source-docs.json",
  "source_doc_scopes": [
    "org"
  ],
  "excluded_surfaces": [
    {
      "surface": "github_app_installations",
      "reason": "excluded_by_user_request"
    },
    {
      "surface": "repositories",
      "reason": "repository inventory and content are not organization settings"
    },
    {
      "surface": "derived_inventory",
      "reason": "ids, timestamps, disk usage, repository counts, collaborator counts, Actions cache usage, packages, and repository inventory are derived state rather than organization settings"
    }
  ],
  "approved_drift": {
    "exclusions": [],
    "allowances": []
  },
  "non_deterministic_review_file": "github-org-nondeterministic-contract.json",
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": "--apply"
  },
  "fetch_bundles": [
    {
      "id": "core_org_bundle",
      "purpose": "Fetch profile, member privilege, repository policy, billing-plan, and legacy security-default fields in one response.",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}",
          "covers_checks": [
            "org.settings",
            "org.plan",
            "org.logo_custom_avatar"
          ]
        }
      ]
    },
    {
      "id": "actions_bundle",
      "purpose": "Fetch organization Actions settings in a small group.",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/permissions",
          "covers_checks": [
            "actions.permissions",
            "actions.selected_actions"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/permissions/workflow",
          "covers_checks": [
            "actions.workflow_permissions"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/permissions/artifact-and-log-retention",
          "covers_checks": [
            "actions.artifact_log_retention"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/permissions/fork-pr-contributor-approval",
          "covers_checks": [
            "actions.fork_pr_contributor_approval"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/oidc/customization/sub",
          "covers_checks": [
            "actions.oidc_subject_claim_template"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/runner-groups",
          "covers_checks": [
            "actions.runner_groups"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/runners",
          "covers_checks": [
            "actions.runners"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/secrets",
          "covers_checks": [
            "actions.secrets"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/actions/variables",
          "covers_checks": [
            "actions.variables"
          ]
        }
      ]
    },
    {
      "id": "security_dependabot_bundle",
      "purpose": "Fetch no-extra-cost security, Dependabot, and private registry policy surfaces.",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/code-security/configurations",
          "covers_checks": [
            "code_security.configurations"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/code-security/configurations/defaults",
          "covers_checks": [
            "code_security.configuration_defaults"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/dependabot/repository-access",
          "covers_checks": [
            "dependabot.repository_access"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/dependabot/secrets",
          "covers_checks": [
            "dependabot.secrets"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/dependabot/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "dependabot.open_alert_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/search/issues?q=org:${org_login}+is:pr+is:open+author:app/dependabot&per_page=100",
          "paginate": true,
          "covers_checks": [
            "dependabot.open_pr_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/private-registries",
          "covers_checks": [
            "private_registries.configurations"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/security-managers",
          "covers_checks": [
            "organization.security_managers"
          ]
        }
      ]
    },
    {
      "id": "governance_bundle",
      "purpose": "Fetch people, teams, moderation, release, issue metadata, custom properties, and plan-limited governance surfaces.",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/properties/schema",
          "covers_checks": [
            "custom_properties.schema"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/organization-roles",
          "covers_checks": [
            "organization.roles"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/custom-repository-roles",
          "covers_checks": [
            "organization.custom_repository_roles"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/hooks",
          "covers_checks": [
            "organization.webhooks"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/teams",
          "covers_checks": [
            "organization.teams"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/members",
          "covers_checks": [
            "organization.members"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/outside_collaborators",
          "covers_checks": [
            "organization.outside_collaborators"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/invitations",
          "covers_checks": [
            "organization.invitations"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/failed_invitations",
          "covers_checks": [
            "organization.failed_invitations"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/blocks",
          "covers_checks": [
            "organization.blocked_users"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/interaction-limits",
          "covers_checks": [
            "organization.interaction_limits"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/issue-types",
          "covers_checks": [
            "organization.issue_types"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/issue-fields",
          "covers_checks": [
            "organization.issue_fields"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/settings/immutable-releases",
          "covers_checks": [
            "organization.immutable_releases"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/settings/immutable-releases/repositories",
          "covers_checks": [
            "organization.immutable_releases_selected_repositories"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/announcement",
          "covers_checks": [
            "organization.announcement_banner"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/rulesets",
          "covers_checks": [
            "organization.rulesets"
          ]
        }
      ]
    },
    {
      "id": "unavailable_or_plan_limited_bundle",
      "purpose": "Confirm same no-feature or no-scope state for currently unavailable settings surfaces.",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/personal-access-token-requests",
          "covers_checks": [
            "organization.personal_access_token_requests"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/codespaces/secrets",
          "covers_checks": [
            "codespaces.secrets"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${org_login}/settings/network-configurations",
          "covers_checks": [
            "hosted_compute.network_configurations"
          ]
        }
      ]
    }
  ],
