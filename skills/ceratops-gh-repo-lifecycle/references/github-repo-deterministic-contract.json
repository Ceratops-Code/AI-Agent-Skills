{
  "contract_format_version": 2,
  "kind": "github_repository_contract",
  "name": "ceratops_github_repo_deterministic_contract",
  "captured_on": "2026-05-02",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-gh-repo-lifecycle/references/contract-source-docs.json",
      "lines": "source-doc registry"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-gh-repo-lifecycle/references/health-audit.md",
      "lines": "contract owner"
    }
  ],
  "parameters": {
    "owner": {
      "type": "string",
      "required": true
    },
    "repo": {
      "type": "string",
      "required": true
    },
    "default_branch": {
      "type": "string",
      "required": false,
      "default_from": "repo.default_branch"
    },
    "expected_codeowners_owners": {
      "type": "array",
      "required": false,
      "default": []
    },
    "expected_required_checks": {
      "type": "array",
      "required": false,
      "default": []
    },
    "artifact_publishers": {
      "type": "array",
      "required": false,
      "default": []
    },
    "local_repo_path": {
      "type": "string",
      "required": false
    },
    "expected_maintainer_bypass_actors": {
      "type": "array",
      "required": false,
      "default": []
    },
    "approved_drift_profile": {
      "type": "string",
      "required": false,
      "default": "default"
    }
  },
  "required_scopes": [
    "repo",
    "workflow"
  ],
  "optional_scopes_for_full_screen_parity": [
    {
      "scope": "admin:org",
      "enables": [
        "security.code_security_configuration_attached"
      ],
      "reason": "Needed only when the checker must verify org-level code security configuration attachment/default posture for repositories owned by an organization."
    }
  ],
  "source_docs_ref": "contract-source-docs.json",
  "source_doc_scopes": [
    "repo"
  ],
  "approved_drift": {
    "exclusions": [],
    "allowances": [
      {
        "id": "forks_may_defer_enforcement_to_upstream",
        "when": "repo.fork == true",
        "check_ids": [
          "process.default_branch_enforcement_present",
          "process.branch_protection_or_ruleset_posture",
          "security.dependency_review_availability"
        ],
        "reason": "Forks can have unavailable or upstream-owned enforcement surfaces; classify rather than mutate."
      },
      {
        "id": "archived_repos_report_only",
        "when": "repo.archived == true",
        "check_ids": [
          "*"
        ],
        "reason": "Archived repositories are immutable health inventory, not repair targets."
      }
    ]
  },
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": "--apply",
    "auto_apply_check_ids": [
      "repo.merge_settings",
      "security.dependabot_security_updates_enabled",
      "security.vulnerability_alerts_enabled",
      "security.private_vulnerability_reporting_public",
      "content.dependencies_label_when_dependabot_uses_it"
    ],
    "manual_check_ids": [
      "repo.identity_public_contract",
      "process.default_branch_enforcement_present",
      "process.branch_protection_or_ruleset_posture",
      "security.open_dependabot_pr_queue",
      "stale_state.*"
    ],
    "destructive_or_irreversible": "always_report_only"
  },
  "fetch_bundles": [
    {
      "id": "repo_identity_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}",
          "covers_checks": [
            "repo.identity_public_contract",
            "repo.unused_feature_flags",
            "repo.merge_settings",
            "security.security_and_analysis_status",
            "type.visibility_origin_lifecycle"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/topics",
          "covers_checks": [
            "repo.topics_required",
            "type.topic_signals"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/community/profile",
          "covers_checks": [
            "content.community_profile_public"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/orgs/${owner}",
          "covers_checks": [
            "repo.merge_settings"
          ]
        }
      ]
    },
    {
      "id": "local_repo_scan_bundle",
      "sources": [
        "${local_repo_path}"
      ],
      "covers_checks": [
        "actions.permissions_policy",
        "content.dependencies_label_when_dependabot_uses_it"
      ],
      "applies_when": "local_repo_path is provided"
    },
    {
      "id": "process_enforcement_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/rulesets",
          "covers_checks": [
            "process.default_branch_enforcement_present",
            "process.branch_protection_or_ruleset_posture",
            "process.maintainer_bypass_ruleset"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/branches/${default_branch}/protection",
          "covers_checks": [
            "process.default_branch_name_and_protection_indicator",
            "process.default_branch_enforcement_present",
            "process.branch_protection_or_ruleset_posture"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/collaborators/${actor}/permission",
          "covers_checks": [
            "process.maintainer_bypass_ruleset"
          ]
        }
      ]
    },
    {
      "id": "actions_policy_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions",
          "covers_checks": [
            "actions.permissions_policy"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/workflow",
          "covers_checks": [
            "actions.workflow_token_permissions"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/artifact-and-log-retention",
          "covers_checks": [
            "actions.artifact_log_retention"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/fork-pr-contributor-approval",
          "covers_checks": [
            "actions.fork_pr_contributor_approval"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/permissions/fork-pr-workflows-private-repos",
          "covers_checks": [
            "actions.private_fork_pr_workflows"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/actions/runs?branch=${default_branch}&per_page=20",
          "covers_checks": [
            "actions.latest_default_branch_runs"
          ]
        }
      ]
    },
    {
      "id": "security_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/vulnerability-alerts",
          "covers_checks": [
            "security.vulnerability_alerts_enabled"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/automated-security-fixes",
          "covers_checks": [
            "security.dependabot_security_updates_enabled"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/dependabot/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_dependabot_alert_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-scanning/default-setup",
          "covers_checks": [
            "security.code_scanning_default_setup_or_custom"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-scanning/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_code_scanning_alert_queue",
            "security.code_scanning_default_setup_or_custom"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/secret-scanning/alerts?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "security.open_secret_scanning_alert_queue"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/private-vulnerability-reporting",
          "covers_checks": [
            "security.private_vulnerability_reporting_public"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/dependency-graph/compare/${default_branch}...${default_branch}",
          "applies_when": "repo.archived == false && (repo.visibility != private || repo.security_and_analysis.code_security.status == enabled || repo.security_and_analysis.advanced_security.status == enabled)",
          "covers_checks": [
            "security.dependency_review_availability"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/code-security-configuration",
          "covers_checks": [
            "security.code_security_configuration_attached"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/labels/dependencies",
          "covers_checks": [
            "content.dependencies_label_when_dependabot_uses_it"
          ]
        }
      ]
    },
    {
      "id": "release_and_stale_state_bundle",
      "requests": [
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/releases?per_page=100",
          "paginate": true,
          "covers_checks": [
            "stale_state.releases"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/tags?per_page=100",
          "paginate": true,
          "covers_checks": [
            "stale_state.tags"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/branches?per_page=100",
          "paginate": true,
          "covers_checks": [
            "stale_state.branches"
          ]
        },
        {
          "method": "GET",
          "endpoint": "/repos/${owner}/${repo}/pulls?state=open&per_page=100",
          "paginate": true,
          "covers_checks": [
            "stale_state.pull_requests"
          ]
        }
      ]
    }
  ],
  "checks": [
    {
      "id": "type.visibility_origin_lifecycle",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "classification",
      "applies_when": "always",
      "assertions": [
        {
          "path": "/repository/types/visibility",
          "operator": "not_empty"
        },
        {
          "path": "/repository/types/origin",
          "operator": "not_empty"
        },
        {
          "path": "/repository/types/lifecycle",
          "operator": "not_empty"
        }
      ]
    },
    {
      "id": "type.topic_signals",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "classification",
      "applies_when": "always",
      "assertions": [
        {
          "path": "/repository/types",
          "operator": "truthy"
        }
      ]
    },
    {
      "id": "repo.identity_public_contract",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "applies_when": "repo.archived == false",
      "assertions": [
        {
          "path": "/repository/repo/owner/login",
          "operator": "equal_ci",
          "expected": "${owner}"
        },
        {
          "path": "/repository/repo/name",
          "operator": "equal_ci",
          "expected": "${repo}"
        },
        {
          "path": "/repository/repo/default_branch",
          "operator": "equal",
          "expected": "${default_branch}"
        },
        {
          "path": "/repository/repo/visibility",
          "operator": "in",
          "expected": [
            "public",
            "private",
            "internal"
          ]
        },
        {
          "path": "/repository/repo/description",
          "operator": "not_empty",
          "level": "ERROR",
          "when": "repo.visibility == public"
        }
      ]
    },
    {
      "id": "repo.topics_required",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/topics",
      "applies_when": "repo.archived == false",
      "assertions": [
        {
          "path": "/repository/topics",
          "operator": "not_empty",
          "when": "repo.visibility == public"
        }
      ],
      "remediation": "Set repository topics from the repository's actual purpose; the validator cannot infer semantic topic names safely."
    },
    {
      "id": "repo.unused_feature_flags",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/create-or-publish.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "applies_when": "repo.archived == false",
      "assertions": [
        {
          "path": "/repository/repo/has_wiki",
          "operator": "equal",
          "expected": false,
          "level": "WARN"
        },
        {
          "path": "/repository/repo/has_projects",
          "operator": "equal",
          "expected": false,
          "level": "WARN"
        },
        {
          "path": "/repository/repo/has_discussions",
          "operator": "equal",
          "expected": false,
          "level": "WARN"
        }
      ]
    },
    {
      "id": "repo.merge_settings",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}",
      "applies_when": "repo.archived == false && repo.fork == false",
      "profile_defaults": {
        "merge_methods": {
          "allow_squash_merge": true,
          "allow_merge_commit": "allowed_if_approved",
          "allow_rebase_merge": "allowed_if_approved"
        }
      },
      "assertions": [
        {
          "path": "/repository/repo/allow_auto_merge",
          "operator": "equal",
          "expected": true,
          "level": "WARN",
          "when": "repo.visibility != private || owner.plan.name != free"
        },
        {
          "path": "/repository/repo/delete_branch_on_merge",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/repository/repo/allow_update_branch",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        }
      ],
      "remediation_action": "repository.update_settings"
    },
    {
      "id": "process.default_branch_name_and_protection_indicator",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/branches/${default_branch}",
      "applies_when": "repo.visibility == public && repo.archived == false && repo.fork == false",
      "assertions": [
        {
          "path": "/repository/repo/default_branch",
          "operator": "equal",
          "expected": "${default_branch}"
        },
        {
          "path": "/repository/enforcement",
          "operator": "any_true"
        }
      ]
    },
    {
      "id": "process.default_branch_enforcement_present",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api_composite",
      "endpoints": [
        "/repos/${owner}/${repo}/rulesets",
        "/repos/${owner}/${repo}/branches/${default_branch}/protection"
      ],
      "applies_when": "repo.visibility == public && repo.archived == false && repo.fork == false",
      "assertions": [
        {
          "path": "/repository/enforcement",
          "operator": "any_true"
        }
      ]
    },
    {
      "id": "process.branch_protection_or_ruleset_posture",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api_composite",
      "applies_when": "repo.visibility == public && repo.archived == false && repo.fork == false",
      "assertions": [
        {
          "path": "/repository/protection_facts/strict",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/protection_facts/required_checks",
          "operator": "not_empty"
        },
        {
          "path": "/repository/protection_facts/approving_reviews",
          "operator": "gte",
          "expected": 1,
          "level": "WARN"
        },
        {
          "path": "/repository/protection_facts/dismiss_stale_reviews",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/protection_facts/code_owner_reviews",
          "operator": "equal",
          "expected": true,
          "level": "WARN",
          "when": "repository.codeowners_present"
        },
        {
          "path": "/repository/protection_facts/conversation_resolution",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/protection_facts/enforce_admins",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/protection_facts/allow_force_pushes",
          "operator": "equal",
          "expected": false
        },
        {
          "path": "/repository/protection_facts/allow_deletions",
          "operator": "equal",
          "expected": false
        }
      ]
    },
    {
      "id": "process.maintainer_bypass_ruleset",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/create-or-publish.md"
      ],
      "kind": "api_composite",
      "endpoints": [
        "/repos/${owner}/${repo}/rulesets",
        "/repos/${owner}/${repo}/branches/${default_branch}/protection"
      ],
      "applies_when": "expected_maintainer_bypass_actors is not empty && repo.archived == false && repo.fork == false",
      "assertions": [
        {
          "path": "/repository/rulesets/expected_actors_present",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/rulesets/pull_request_only_visible",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/repository/rulesets/default_branch_target_visible",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/repository/rulesets/enforcement_rule_visible",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        }
      ]
    },
    {
      "id": "actions.permissions_policy",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/actions/permissions",
      "applies_when": "repo.archived == false && type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/repository/actions/permissions/enabled",
          "operator": "equal",
          "expected": true
        },
        {
          "path": "/repository/actions/permissions/sha_pinning_required",
          "operator": "equal",
          "expected": true,
          "level": "WARN",
          "when": "local.workflows.unpinned_external_refs is empty"
        }
      ]
    },
    {
      "id": "actions.workflow_token_permissions",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api_and_tree",
      "endpoint": "/repos/${owner}/${repo}/actions/permissions/workflow",
      "applies_when": "repo.archived == false && type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/repository/actions/workflow_permissions/default_workflow_permissions",
          "operator": "equal",
          "expected": "read"
        },
        {
          "path": "/repository/actions/workflow_permissions/can_approve_pull_request_reviews",
          "operator": "equal",
          "expected": false
        },
        {
          "path": "/local/workflows/permissions_write_all",
          "operator": "empty"
        },
        {
          "path": "/local/workflows/top_level_write/attestations",
          "operator": "empty"
        },
        {
          "path": "/local/workflows/top_level_write/artifact-metadata",
          "operator": "empty"
        }
      ]
    },
    {
      "id": "actions.artifact_log_retention",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/actions/permissions/artifact-and-log-retention",
      "applies_when": "repo.archived == false && type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/repository/actions/retention/days",
          "operator": "lte",
          "expected": 90
        }
      ]
    },
    {
      "id": "actions.fork_pr_contributor_approval",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/actions/permissions/fork-pr-contributor-approval",
      "applies_when": "repo.visibility == public && repo.archived == false && type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/repository/actions/fork_approval/approval_policy",
          "operator": "in",
          "expected": [
            "first_time_contributors",
            "all_external_contributors"
          ]
        }
      ]
    },
    {
      "id": "actions.private_fork_pr_workflows",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/actions/permissions/fork-pr-workflows-private-repos",
      "applies_when": "repo.visibility in [private,internal] && repo.archived == false",
      "assertions": [
        {
          "path": "/repository/actions/private_fork/send_write_tokens_to_workflows",
          "operator": "equal",
          "expected": false
        },
        {
          "path": "/repository/actions/private_fork/send_secrets_and_variables",
          "operator": "equal",
          "expected": false
        },
        {
          "path": "/repository/actions/private_fork/require_approval_for_fork_pr_workflows",
          "operator": "equal",
          "expected": true,
          "when": "repository.private_fork_enabled"
        }
      ]
    },
    {
      "id": "actions.latest_default_branch_runs",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/create-or-publish.md"
      ],
      "kind": "api",
      "endpoint": "/repos/${owner}/${repo}/actions/runs?branch=${default_branch}&per_page=20",
      "applies_when": "repo.archived == false && type.workflow_surface has has_workflows",
      "assertions": [
        {
          "path": "/repository/actions/runs/available",
          "operator": "equal",
          "expected": true,
          "level": "WARN"
        },
        {
          "path": "/repository/actions/runs/count",
          "operator": "gt",
          "expected": 0,
          "level": "WARN"
        },
        {
          "path": "/repository/actions/runs/failed",
          "operator": "empty"
        }
      ]
    },
    {
      "id": "security.security_and_analysis_status",
      "source_lines": [
        "skills/ceratops-gh-repo-lifecycle/references/health-audit.md"
      ],
