{
  "contract_format_version": 1,
  "kind": "skill_design_contract",
  "name": "ceratops_skill_deterministic_contract",
  "captured_on": "2026-07-20",
  "source_files": [
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-skill-lifecycle/references/skill-source-docs.json",
      "lines": "source-doc registry, skill standards, and installed skill references"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py",
      "lines": "deterministic skill source, metadata, runtime, contract, and portability checks"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-skill-lifecycle/scripts/runtime/managed_runtime_builder.py",
      "lines": "source-scoped managed runtime ownership and stale cleanup"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py",
      "lines": "installed managed runtime identity and complete file-tree comparison"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/skills/ceratops-skill-lifecycle/scripts/templates/install-skills-template.py",
      "lines": "authoritative versioned compatible-repository installer"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/templates/skill-sections.json",
      "lines": "shared section and runtime payload ownership"
    },
    {
      "path": "$AI_AGENT_SKILLS_ROOT/AGENTS.md",
      "lines": "skill maintenance and source-of-truth rules"
    }
  ],
  "parameters": {
    "skill_name": {
      "type": "string",
      "required": true
    },
    "skill_dir": {
      "type": "string",
      "required": false,
      "default_from": "skills/${skill_name}"
    },
    "validation_mode": {
      "type": "string",
      "required": false,
      "default": "full",
      "allowed": [
        "skill",
        "sections",
        "full"
      ]
    }
  },
  "required_scopes": [
    "skill"
  ],
  "source_docs_ref": "skill-source-docs.json",
  "source_doc_scopes": [
    "skill"
  ],
  "non_deterministic_review_file": "skill-nondeterministic-contract.json",
  "remediation_policy": {
    "default": "report_only",
    "apply_flag": null,
    "auto_apply_check_ids": [],
    "ai_agent_check_ids": [
      "skill.repository_identity_and_profile",
      "skill.installer_version_consistency",
      "skill.frontmatter_and_layout",
      "skill.metadata_alignment",
      "skill.runtime_payload_portability",
      "skill.runtime_source_ownership",
      "skill.shared_section_generation",
      "skill.multi_action_contract",
      "skill.resource_layout",
      "skill.public_doc_alignment",
      "skill.private_path_and_secret_absence",
      "skill.contract_reference_alignment",
      "skill.governance_consistency_audit"
    ],
    "destructive_or_irreversible": "always_report_only"
  },
  "execution": {
    "source_validator": "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py",
    "skill_validation_command": "python skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py --mode skill --skill <skill-name>",
    "full_validation_command": "python skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py --mode full",
    "section_validation_command": "python skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py --mode sections",
    "runtime_validation_command": "python skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py --repo-root <repo-root> --skill <skill-name>",
    "result_contract": "Exit 0 with an ok line when selected deterministic checks pass; nonzero with line-specific errors when they fail."
  },
  "checks": [
    {
      "id": "skill.repository_identity_and_profile",
      "category": "runtime",
      "deterministic_evidence": [
        "templates/skill-sections.json runtime_source_id",
        "templates/skill-sections.json validation_profile"
      ],
      "pass_condition": "The source manifest declares a nonempty stable runtime_source_id and either the ceratops or ceratops-compatible validation profile; full validation always applies common checks and only the ceratops profile adds Ceratops-specific icon, contract, retired-artifact, and repository-governance checks.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_repo_manifest_identity",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:main"
      ]
    },
    {
      "id": "skill.installer_version_consistency",
      "category": "runtime",
      "deterministic_evidence": [
        "scripts/install-skills.py INSTALLER_VERSION",
        "authoritative installer template INSTALLER_VERSION",
        "installed runtime manifest installer_version"
      ],
      "pass_condition": "Compatible repositories declare one positive integer INSTALLER_VERSION in scripts/install-skills.py; selected-skill consistency compares only that value, updates missing or lower versions through task worktrees, retains same-version content differences, and runs full validation after synchronization.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/runtime/synchronize-installers.py:installer_version",
        "skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py:discover_runtime",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_source_installer"
      ]
    },
    {
      "id": "skill.frontmatter_and_layout",
      "category": "source",
      "deterministic_evidence": [
        "skill directory name",
        "source SKILL.md frontmatter",
        "source SKILL.md section and subsection structure"
      ],
      "pass_condition": "Source skill frontmatter contains only name and description, frontmatter name matches the directory, description is present, and the body contains a Markdown H2 section structure; the ceratops profile additionally requires Boundaries and Output Contract subsections.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:parse_frontmatter",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_skill"
      ]
    },
    {
      "id": "skill.metadata_alignment",
      "category": "metadata",
      "deterministic_evidence": [
        "skills/<skill-name>/agents/openai.yaml",
        "source SKILL.md description"
      ],
      "pass_condition": "OpenAI interface metadata exists, default_prompt names the skill, display name resembles the skill identity, and short description overlaps the trigger description; the ceratops profile additionally requires icon fields, shared Ceratops icon paths, and matching bytes.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:parse_openai_interface",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:display_name_sane",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:short_description_relevant",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_skill"
      ]
    },
    {
      "id": "skill.shared_section_generation",
      "category": "runtime",
      "deterministic_evidence": [
        "templates/skill-sections.json",
        "templates/sections/*",
        "source SKILL.md"
      ],
      "pass_condition": "Every source skill has a manifest assignment including core, source SKILL.md files remain delta-only, assigned shared sections render, and source files do not contain generated runtime shared-section blocks.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:rendered_sections_block",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_section_sources",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_skill"
      ]
    },
    {
      "id": "skill.multi_action_contract",
      "category": "source",
      "deterministic_evidence": [
        "templates/skill-sections.json multi-action-skill assignments",
        "skills/<skill-name>/SKILL.md Action References",
        "skills/<skill-name>/references/*.md action titles"
      ],
      "pass_condition": "Every skill assigned the multi-action-skill section has one complete Action References index with at least two unique direct references/*.md paths; every mapped file exists and uses an Action title, and every top-level reference with an Action title is indexed.",
      "source_lines": [
        "templates/sections/multi-action-skill.md:Multi-Action Skill Contract",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_multi_action_skill_contract"
      ]
    },
    {
      "id": "skill.resource_layout",
      "category": "source",
      "deterministic_evidence": [
        "skill top-level files and directories",
        "skills/<skill-name>/references/"
      ],
      "pass_condition": "Each skill folder contains `SKILL.md` as the only top-level file and uses only profile-supported resource directories; the compatible profile may include `tests/`, while the ceratops profile allows `agents/`, `assets/`, `scripts/`, and `references/`. Reference files remain within supported nesting.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_resource_layout"
      ]
    },
    {
      "id": "skill.runtime_payload_portability",
      "category": "runtime",
      "deterministic_evidence": [
        "templates/skill-sections.json runtime_payloads",
        "declared payload paths"
      ],
      "pass_condition": "Runtime payload declarations point only to existing repo-relative paths or matching globs and do not use absolute paths or parent-directory traversal.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_runtime_payloads"
      ]
    },
    {
      "id": "skill.runtime_source_ownership",
      "category": "runtime",
      "deterministic_evidence": [
        "source manifest runtime_source_id",
        "installed .runtime-manifest.json ownership",
        "installed source_repository_root and installer_version",
        "selected install scope"
      ],
      "pass_condition": "Full installation runs full source-repository validation before building; explicit skill installation validates only selected skills. Runtime manifests record schema, skill, runtime_source_id, source_path, source_repository_root, validation_profile, and installer_version. The builder preflights all selected targets, refuses unmanaged folders, links, invalid ownership, and same-name folders owned by another source; a full install removes only stale folders with the same runtime_source_id, while an explicit targeted install removes none. Runtime validation can select one direct manifest-backed skill and compare only its complete managed file tree with canonical builder output.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/runtime/resolve-lifecycle-bundle.py:resolve_bundle",
        "skills/ceratops-skill-lifecycle/scripts/runtime/install-managed-skills.py:main",
        "skills/ceratops-skill-lifecycle/scripts/runtime/managed_runtime_builder.py:validate_install_targets",
        "skills/ceratops-skill-lifecycle/scripts/runtime/managed_runtime_builder.py:remove_stale_managed_skills",
        "skills/ceratops-skill-lifecycle/scripts/runtime/managed_runtime_builder.py:write_expected_skill",
        "skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py:discover_runtime",
        "skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py:validate_runtime"
      ]
    },
    {
      "id": "skill.public_doc_alignment",
      "category": "docs",
      "deterministic_evidence": [
        "README.md skill table",
        "skills/<skill-name>/SKILL.md"
      ],
      "pass_condition": "Every source skill has a row in the README Skills table and every row in that table points to an existing source skill directory, without requiring a name prefix.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:readme_skill_rows",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_skill"
      ]
    },
    {
      "id": "skill.private_path_and_secret_absence",
      "category": "safety",
      "deterministic_evidence": [
        "repo text files"
      ],
      "pass_condition": "Repo-tracked text files do not contain high-confidence secret patterns or user-local absolute filesystem paths.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:SECRET_PATTERNS",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_secrets"
      ]
    },
    {
      "id": "skill.contract_reference_alignment",
      "category": "contracts",
      "deterministic_evidence": [
        "skills/ceratops-skill-lifecycle/references/contracts/skill-deterministic-contract.json",
        "skills/ceratops-skill-lifecycle/references/contracts/skill-nondeterministic-contract.json",
        "skill-source-docs.json",
        "skills/ceratops-skill-lifecycle/references/skills-contract-review.md",
        "skills/ceratops-skill-lifecycle/references/skills-consistency-review.md",
        "README.md"
      ],
      "pass_condition": "The source-doc registry and contract-review action own skill-design standards refresh, the validator owns deterministic compliance, and the repository consistency action owns manual non-deterministic compliance without silently changing the contracts.",
      "source_lines": [
        "skill-source-docs.json:docs scope skill",
        "skill-source-docs.json:reference_skills",
        "skills/ceratops-skill-lifecycle/references/skills-contract-review.md:References",
        "skills/ceratops-skill-lifecycle/references/skills-consistency-review.md:References",
        "README.md:Contracts"
      ]
    },
    {
      "id": "skill.governance_consistency_audit",
      "category": "governance",
      "deterministic_evidence": [
        "source skill identities",
        "installed managed runtime manifests",
        "repository and installed installer versions",
        "validation command surfaces",
        "skill deterministic and nondeterministic contract mappings",
        "multi-action lifecycle action references and command snippets"
      ],
      "pass_condition": "Full source validation checks rename completeness, current-source skill references, README alignment, and profile-aware source governance; selected runtime checks validate one direct manifest-backed skill's installed ownership and identity without one-time stale-term detectors.",
      "source_lines": [
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_source_governance_consistency",
        "skills/ceratops-skill-lifecycle/scripts/skills-consistency-source-validator.py:check_skill_contract_remediation_policy",
        "skills/ceratops-skill-lifecycle/scripts/runtime/skills-consistency-runtime-validator.py:validate_runtime",
        "skills/ceratops-skill-lifecycle/references/skills-consistency-review.md:Goal",
        "README.md:Validate"
